<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DataTemplate x:Key="Collimation Helper for SkyWave_Options">
        <StackPanel Orientation="Vertical" MaxWidth="640" Margin="5">

            <TextBlock Text="All settings are in the Collimation Helper panel (Imaging tab). Equipment data is read from your NINA profile automatically."
                       Foreground="#888" FontSize="10" Margin="0,0,0,6" FontStyle="Italic" TextWrapping="Wrap" />

            <!-- Support link -->
            <Button Command="{Binding OpenCoffeeCommand}" Cursor="Hand"
                    HorizontalAlignment="Left" Margin="0,6,0,2"
                    Background="Transparent" BorderBrush="Transparent" Padding="0">
                <TextBlock Text="Wanna buy me a supporting coffee?" FontSize="11" Foreground="#4FC3F7"
                           TextDecorations="Underline" />
            </Button>

            <TextBlock Margin="0,2,0,0" FontSize="10" Foreground="#888" TextWrapping="Wrap"
                       Text="v2.0.0 by joergsflow | Collimation Helper for SkyWave | innovationsforesight.com/aitelescopecollimation" />
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
