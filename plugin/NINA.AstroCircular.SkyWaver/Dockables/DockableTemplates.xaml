<ResourceDictionary
    x:Class="NINA.AstroCircular.SkyWaver.Dockables.DockableTemplates"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Plugin icon: 3 concentric rings + center dot (collimation target) -->
    <GeometryGroup x:Key="SkwCollimationSVG" FillRule="EvenOdd">
        <PathGeometry Figures="M 1.5,16 A 14.5,14.5 0 1 1 30.5,16 A 14.5,14.5 0 1 1 1.5,16 Z" />
        <PathGeometry Figures="M 2.8,16 A 13.2,13.2 0 1 1 29.2,16 A 13.2,13.2 0 1 1 2.8,16 Z" />
        <PathGeometry Figures="M 6.5,16 A 9.5,9.5 0 1 1 25.5,16 A 9.5,9.5 0 1 1 6.5,16 Z" />
        <PathGeometry Figures="M 7.8,16 A 8.2,8.2 0 1 1 24.2,16 A 8.2,8.2 0 1 1 7.8,16 Z" />
        <PathGeometry Figures="M 11,16 A 5,5 0 1 1 21,16 A 5,5 0 1 1 11,16 Z" />
        <PathGeometry Figures="M 12.3,16 A 3.7,3.7 0 1 1 19.7,16 A 3.7,3.7 0 1 1 12.3,16 Z" />
        <PathGeometry Figures="M 14.8,16 A 1.2,1.2 0 1 1 17.2,16 A 1.2,1.2 0 1 1 14.8,16 Z" />
    </GeometryGroup>

    <DataTemplate x:Key="NINA.AstroCircular.SkyWaver.Dockables.SkwPanelVM_Dockable">
        <StackPanel Margin="5">

            <!-- Star Selection -->
            <Grid Margin="0,0,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Star:" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="Bold" />
                <ComboBox Grid.Column="1" ItemsSource="{Binding StarPresets}" SelectedItem="{Binding SelectedPreset}"
                          DisplayMemberPath="DisplayLabel" Margin="0,0,4,0" />
                <Button Grid.Column="2" Content="Find Best" Command="{Binding FindBestStarCommand}" Padding="8,2" />
            </Grid>

            <!-- RA / Dec -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="32" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="RA" VerticalAlignment="Center" FontSize="11" />
                <TextBox Grid.Column="1" Text="{Binding TargetRA, UpdateSourceTrigger=PropertyChanged}" Margin="2,0" FontSize="11" />
                <TextBlock Grid.Column="2" Text="Dec" VerticalAlignment="Center" Margin="6,0,0,0" FontSize="11" />
                <TextBox Grid.Column="3" Text="{Binding TargetDec, UpdateSourceTrigger=PropertyChanged}" Margin="2,0" FontSize="11" />
            </Grid>

            <!-- Parameters (compact 3-column grid) -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="42" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="46" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Defocus" VerticalAlignment="Center" FontSize="11" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DefocusSteps, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11"
                         ToolTip="Defocus in focuser steps — must match the value calculated by SkyWave for your setup.&#x0a;&#x0a;How to calculate:&#x0a;1. Run SkyWave to get the required defocus in microns&#x0a;2. Divide by your focuser's µm/step ratio&#x0a;3. Enter the result here&#x0a;&#x0a;Example: SkyWave says 7326 µm ÷ 3 µm/step = 2442 steps" />
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding MicronsPerStep, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11"
                         ToolTip="Microns of focuser travel per step — depends on your focuser + OAZ combination.&#x0a;&#x0a;How to measure:&#x0a;1. Move focuser out by e.g. 10000 steps&#x0a;2. Measure the distance travelled from the scope backplate&#x0a;3. Divide distance (µm) by number of steps&#x0a;&#x0a;Example: ZWO EAF + FeatherTouch OAZ on RC12 ≈ 3 µm/step" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="µm/st" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0"
                           ToolTip="Microns per step — specific to your focuser + OAZ combination" />
                <TextBlock Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="2" Text="{Binding DefocusMicronsText}" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0"
                           Foreground="#888" ToolTip="Computed defocus in microns — compare with the value from SkyWave" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Dir" VerticalAlignment="Center" FontSize="11" />
                <ComboBox Grid.Row="1" Grid.Column="1" SelectedIndex="{Binding DefocusDirectionIndex}" Margin="2,1" FontSize="11">
                    <ComboBoxItem Content="Extra-focal (+)" />
                    <ComboBoxItem Content="Intra-focal (-)" />
                </ComboBox>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Exp s" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding ExposureTime, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Filter" VerticalAlignment="Center" FontSize="11" />
                <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AvailableFilters}"
                          SelectedItem="{Binding FilterName}" Margin="2,1" FontSize="11" />
                <TextBlock Grid.Row="2" Grid.Column="2" Text="Gain" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding Gain, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />
                <TextBlock Grid.Row="2" Grid.Column="4" Text="Offset" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <TextBox Grid.Row="2" Grid.Column="5" Text="{Binding Offset, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Pos." VerticalAlignment="Center" FontSize="11" />
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding RingPositions, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />
                <TextBlock Grid.Row="3" Grid.Column="2" Text="Rad%" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding RadiusPercent, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />
                <TextBlock Grid.Row="3" Grid.Column="4" Text="Settle" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <TextBox Grid.Row="3" Grid.Column="5" Text="{Binding SettleSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />
            </Grid>

            <!-- Defocus setup hint -->
            <Border Background="#1a1f2e" BorderBrush="#2a3050" BorderThickness="1" CornerRadius="3" Margin="0,0,0,4" Padding="6,4">
                <TextBlock FontSize="9.5" Foreground="#8899bb" TextWrapping="Wrap"
                           Text="⚙ Defocus steps must be adjusted for your setup: get the required defocus in microns from SkyWave, then divide by your focuser's µm/step ratio. To find your ratio: move the focuser e.g. 10000 steps, measure the travel distance, divide by 10000." />
            </Border>

            <!-- Toggles -->
            <WrapPanel Margin="0,0,0,4">
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <CheckBox IsChecked="{Binding IncludeCenter}" VerticalAlignment="Center" />
                    <TextBlock Text="Center" Margin="4,0,0,0" FontSize="10" VerticalAlignment="Center"
                               ToolTip="Include center star position" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <CheckBox IsChecked="{Binding RunAutofocus}" VerticalAlignment="Center" />
                    <TextBlock Text="AF first" Margin="4,0,0,0" FontSize="10" VerticalAlignment="Center"
                               ToolTip="Run autofocus before defocusing" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <CheckBox IsChecked="{Binding CropAfterStack}" VerticalAlignment="Center" />
                    <TextBlock Text="Crop" Margin="4,0,0,0" FontSize="10" VerticalAlignment="Center"
                               ToolTip="Crop stacked image to ring pattern + 100px margin" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding AutoCleanSubFrames}" VerticalAlignment="Center" />
                    <TextBlock Text="Del subs" Margin="4,0,0,0" FontSize="10" VerticalAlignment="Center"
                               ToolTip="Delete individual frames after integration" />
                </StackPanel>
            </WrapPanel>

            <!-- SkyWave Output Folder -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Output:" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0" />
                <TextBox Grid.Column="1" Text="{Binding SkyWaveOutputDirectory, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="10" ToolTip="SkyWave watch folder — integrated FITS saved here" />
                <Button Grid.Column="2" Content=" ... " Command="{Binding BrowseFolderCommand}"
                        Padding="6,1" Margin="2,0,0,0" ToolTip="Browse for output folder" />
            </Grid>

            <!-- Run / Cancel -->
            <Grid Margin="0,0,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Run Collimation" Command="{Binding RunCommand}"
                        Padding="8,6" FontWeight="Bold" FontSize="13"
                        Background="#22a558" Foreground="White" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}"
                        Padding="8,6" Margin="4,0,0,0" FontSize="13"
                        Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}" />
            </Grid>

            <!-- Progress -->
            <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100" Height="8" Margin="0,0,0,2" />
            <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="#999" TextWrapping="Wrap" />

            <!-- Sensor Map + Camera Preview side by side -->
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sensor Map — frame = sensor rectangle, aspect ratio matches real sensor -->
                <Border Grid.Column="0" BorderBrush="#3a4060" BorderThickness="1.5"
                        Background="#080a10" Margin="0,0,2,0"
                        Width="{Binding MapWidth}" Height="{Binding MapHeight}"
                        HorizontalAlignment="Center">
                    <Grid>
                        <Canvas Width="{Binding MapWidth}" Height="{Binding MapHeight}"
                                ClipToBounds="True">
                            <!-- Position dots via ItemsControl -->
                            <ItemsControl ItemsSource="{Binding MapPositions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding CanvasX}" />
                                        <Setter Property="Canvas.Top" Value="{Binding CanvasY}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="-11,-11,0,0">
                                            <Ellipse Width="22" Height="22" StrokeThickness="2">
                                                <Ellipse.Stroke>
                                                    <SolidColorBrush Color="{Binding StrokeColor}" />
                                                </Ellipse.Stroke>
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{Binding FillColor}" Opacity="0.15" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <Ellipse Width="8" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{Binding FillColor}" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Canvas>

                        <!-- Labels overlay -->
                        <TextBlock Text="Pattern" FontSize="9" Foreground="#444"
                                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4,2" />
                        <TextBlock Text="{Binding ProgressText}" FontSize="10" Foreground="#666"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,2" />
                    </Grid>
                </Border>

                <!-- Camera Preview — zoomable with scroll, same aspect ratio as sensor map -->
                <Border Grid.Column="1" BorderBrush="#272d42" BorderThickness="1"
                        Background="#080a10" Margin="2,0,0,0"
                        Width="{Binding MapWidth}" Height="{Binding MapHeight}"
                        HorizontalAlignment="Center">
                    <Grid>
                        <!-- Scrollable zoom container -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                      PanningMode="Both">
                            <Image Source="{Binding LastCapturedImage}" Stretch="Uniform"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor">
                                <Image.LayoutTransform>
                                    <ScaleTransform ScaleX="{Binding PreviewZoom}" ScaleY="{Binding PreviewZoom}" />
                                </Image.LayoutTransform>
                            </Image>
                        </ScrollViewer>

                        <!-- Label + zoom controls overlay -->
                        <TextBlock Text="Last Capture" FontSize="9" Foreground="#444"
                                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4,2"
                                   IsHitTestVisible="False" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                    Margin="0,0,4,3">
                            <Button Content="−" Command="{Binding ZoomOutCommand}" Padding="4,0" FontSize="11"
                                    Width="20" Height="18" Background="#1a1f2e" Foreground="#8899bb"
                                    BorderBrush="#2a3050" ToolTip="Zoom out" />
                            <TextBlock Text="{Binding PreviewZoomText}" FontSize="9" Foreground="#666"
                                       VerticalAlignment="Center" Margin="3,0" MinWidth="22" TextAlignment="Center" />
                            <Button Content="+" Command="{Binding ZoomInCommand}" Padding="4,0" FontSize="11"
                                    Width="20" Height="18" Background="#1a1f2e" Foreground="#8899bb"
                                    BorderBrush="#2a3050" ToolTip="Zoom in" />
                            <Button Content="1:1" Command="{Binding ZoomResetCommand}" Padding="3,0" FontSize="9"
                                    Height="18" Margin="3,0,0,0" Background="#1a1f2e" Foreground="#8899bb"
                                    BorderBrush="#2a3050" ToolTip="Reset zoom to fit" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
